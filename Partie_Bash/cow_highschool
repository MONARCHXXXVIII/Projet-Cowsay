#!/bin/bash

# cow_highschool
# La vache prononce la suite des carrés 1, 4, 9, ..., n²
# n est un argument du script

if [ $# -eq 0 ]; then
    echo "Usage: $0 <number>"
    exit 1
fi

n=$1

# Vérifier que l'argument est un nombre positif
if ! [[ "$n" =~ ^[0-9]+$ ]] || [ "$n" -lt 1 ]; then
    echo "Erreur: Veuillez fournir un nombre positif"
    exit 1
fi

i=1
while [ $((i * i)) -le "$n" ]; do
    square=$((i * i))
    clear
    cowsay "$square"
    sleep 1
    i=$((i + 1))
done
